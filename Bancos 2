<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Precio en Bancos - TuPropina</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        /* CSS para el diseño móvil profesional */
        :root {
            --bcv-teal: #008080;
            --bg-color: #f0f4f8;
            --card-bg: #ffffff;
            --text-main: #333333;
            --text-secondary: #777777;
            --up-green: #28a745;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            padding: 0;
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            flex-direction: column;
            height: 100vh; /* Ocupa todo el alto de la pantalla */
            overflow: hidden; /* Evita el desplazamiento en el body */
        }

        /* Barra de Título Superior */
        .header {
            background-color: var(--bcv-teal);
            color: white;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header h1 {
            margin: 0;
            font-size: 20px;
            font-weight: 600;
        }

        .header-icons {
            display: flex;
            gap: 15px;
            font-size: 18px;
        }

        /* Barra de Búsqueda */
        .search-bar-container {
            padding: 10px 20px;
            background-color: white;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        .search-bar {
            width: 100%;
            padding: 12px 15px;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            font-size: 16px;
            box-sizing: border-box;
            background-color: #fafafa;
        }

        /* Contenedor Principal con Desplazamiento */
        .main-content {
            flex: 1; /* Ocupa el espacio restante */
            overflow-y: auto; /* Permite el desplazamiento vertical aquí */
            padding: 20px;
            -webkit-overflow-scrolling: touch; /* Desplazamiento suave en iOS */
        }

        /* Tarjeta de Banco (Card) */
        .bank-card {
            background-color: var(--card-bg);
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            display: flex;
            align-items: center;
            gap: 20px;
            transition: transform 0.2s;
        }

        .bank-card:active {
            transform: scale(0.98); /* Efecto de clic */
        }

        /* Logo del Banco */
        .bank-logo-container {
            width: 70px;
            height: 70px;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: #f0f0f0; /* Color temporal */
            border-radius: 10px;
            overflow: hidden;
        }

        .bank-logo {
            max-width: 90%;
            max-height: 90%;
            object-fit: contain;
        }

        /* Información del Banco */
        .bank-info {
            flex: 1;
        }

        .info-label {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-main);
            margin: 0;
        }

        .info-value {
            font-size: 16px;
            color: var(--text-secondary);
            margin: 0 0 8px 0;
        }

        .price-row {
            display: flex;
            align-items: baseline;
            gap: 5px;
        }

        .price-label {
            font-size: 14px;
            font-weight: 600;
            color: var(--text-main);
            margin: 0;
        }

        .price-value {
            font-size: 22px;
            font-weight: bold;
            color: var(--text-main);
            margin: 0;
        }

        .change-indicator {
            color: var(--up-green);
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 4px;
            margin-left: 10px;
        }

        /* Barra de Navegación Inferior */
        .footer {
            background-color: #f8f9fa;
            border-top: 1px solid #e0e0e0;
            padding: 10px 0;
            display: flex;
            justify-content: space-around;
            position: sticky;
            bottom: 0;
            width: 100%;
            z-index: 100;
        }

        .footer-item {
            text-align: center;
            color: var(--text-secondary);
            font-size: 12px;
            text-decoration: none;
        }

        .footer-item i {
            font-size: 20px;
            margin-bottom: 4px;
            display: block;
        }

        .footer-item.active {
            color: var(--bcv-teal);
        }
    </style>
</head>
<body>

    <div class="header">
        <i class="fas fa-home"></i>
        <h1>Precio en Bancos</h1>
        <div class="header-icons">
            <i class="fas fa-share-alt"></i>
            <i class="fas fa-file-alt"></i>
            <i class="fas fa-power-off"></i>
        </div>
    </div>

    <div class="search-bar-container">
        <input type="text" class="search-bar" placeholder="Banco a Buscar">
    </div>

    <div class="main-content" id="contenedorTarjetas">
        <p style="text-align: center; color: var(--text-secondary);">Cargando tasas...</p>
    </div>

    <div class="footer">
        <a href="#" class="footer-item">
            <i class="fas fa-home"></i>
            Inicio
        </a>
        <a href="#" class="footer-item">
            <i class="fas fa-file-invoice-dollar"></i>
            Facturas
        </a>
        <a href="#" class="footer-item">
            <i class="fas fa-chart-line"></i>
            Reportes
        </a>
        <a href="#" class="footer-item active">
            <i class="fas fa-landmark"></i>
            Bancos
        </a>
        <a href="#" class="footer-item">
            <i class="fas fa-bars"></i>
            Más
        </a>
    </div>

    <script>
        // Tu enlace RAW real de GitHub
        const URL_JSON = "https://raw.githubusercontent.com/alfonsocamacho00089-cloud/captura_bcv.py/main/bancos.json";

        // Función para limpiar códigos raros de acentos (como \u00e9)
        function limpiarNombre(nombre) {
            return nombre
                .replace(/\\u00e9/g, 'é')
                .replace(/\\u00ed/g, 'í')
                .replace(/\\u00f3/g, 'ó')
                .replace(/\\u00fa/g, 'ú')
                .replace(/\\u00f1/g, 'ñ');
        }

        // Función principal para cargar los datos y dibujar las tarjetas
        async function cargarYDibujarTarjetas() {
            try {
                const response = await fetch(URL_JSON);
                const datos = await response.json();
                
                const contenedor = document.getElementById('contenedorTarjetas');
                contenedor.innerHTML = ''; // Limpiar mensaje de carga

                // Fecha de hoy formateada (para simular la actualización individual)
                const hoy = new Date();
                const fechaFormateada = hoy.toLocaleDateString('es-VE') + ', ' + hoy.toLocaleTimeString('es-VE', {hour: '2-digit', minute:'2-digit'});

                // Mapa de logos (Tendrás que conseguir los enlaces reales de las imágenes)
                const logosBancos = {
                    "Banco Nacional de Crédito BNC": "ENLACE_A_LOGO_BNC.png",
                    "BBVA Provincial": "ENLACE_A_LOGO_PROVINCIAL.png",
                    "Banco de Venezuela": "ENLACE_A_LOGO_VENEZUELA.png",
                    // Agrega más según necesites...
                };

                // Iterar sobre cada banco en tu JSON y crear su tarjeta
                datos.forEach(item => {
                    const nombreLimpio = limpiarNombre(item.banco);
                    const precioFormateado = parseFloat(item.precio).toFixed(2);
                    
                    // Definir el logo (usar marcador de posición si no hay logo)
                    const logoSrc = logosBancos[nombreLimpio] || "";
                    const logoHTML = logoSrc 
                        ? `<img src="${logoSrc}" alt="${nombreLimpio}" class="bank-logo">`
                        : `<span style="font-size:10px; text-align:center;">${nombreLimpio.substring(0,3)}</span>`; // Marcador de posición

                    // Crear el HTML de la tarjeta
                    const tarjetaHTML = `
                        <div class="bank-card">
                            <div class="bank-logo-container">
                                ${logoHTML}
                            </div>
                            <div class="bank-info">
                                <p class="info-label">Nombre</p>
                                <p class="info-value">${nombreLimpio}</p>
                                
                                <p class="info-label">Actualizacion</p>
                                <p class="info-value">${fechaFormateada}</p>
                                
                                <div class="price-row">
                                    <p class="price-label">Precio en Bs</p>
                                    <p class="price-value">${precioFormateado}</p>
                                    <div class="change-indicator">
                                        0.72 <i class="fas fa-chart-line"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                    
                    // Añadir la tarjeta al contenedor
                    contenedor.innerHTML += tarjetaHTML;
                });

            } catch (error) {
                console.error("Error cargando los datos:", error);
                document.getElementById('contenedorTarjetas').innerHTML = '<p style="text-align:center; color:red;">Error al cargar los datos.</p>';
            }
        }

        // Ejecutar la función al cargar la página
        cargarYDibujarTarjetas();
    </script>

</body>
</html>
